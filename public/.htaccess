# Compressão gzip para os arquivos servidos
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Assets em /assets/ têm hash no nome (Vite) — podem ser cacheados por 1 ano sem risco,
# porque qualquer mudança no código gera um nome de arquivo novo.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|png|jpg|jpeg|svg|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # index.html não pode ficar em cache — é ele que aponta pros assets com hash atual.
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
